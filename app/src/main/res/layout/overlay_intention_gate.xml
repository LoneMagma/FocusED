<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_card"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="16dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_drag_handle"/>

    <TextView
        android:id="@+id/tv_intention_prompt"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:lineSpacingMultiplier="1.15"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/container_intentions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"/>

    <Button
        android:id="@+id/btn_intention_skip"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:text="Just browsing"
        android:textSize="14sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="sans-serif"
        android:background="@drawable/bg_btn_ghost"/>

</LinearLayout>
