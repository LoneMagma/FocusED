<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_card"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="20dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_drag_handle"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Worth it?"
        android:textSize="22sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="8dp"/>

    <TextView
        android:id="@+id/tv_reflection_body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="24dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">

        <Button
            android:id="@+id/btn_reflection_no"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Not really"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:background="@drawable/bg_btn_elevated"/>

        <Button
            android:id="@+id/btn_reflection_yes"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:text="Yes, good use"
            android:textSize="14sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_btn_elevated"/>

    </LinearLayout>

    <Button
        android:id="@+id/btn_reflection_dismiss"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:text="Skip"
        android:textSize="13sp"
        android:textColor="@color/text_disabled"
        android:fontFamily="sans-serif"
        android:background="@drawable/bg_btn_ghost"/>

</LinearLayout>
