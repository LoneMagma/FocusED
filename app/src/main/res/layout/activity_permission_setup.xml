<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <!-- Top section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="60dp">

        <TextView
            android:id="@+id/tv_step_counter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Step 1 of 3"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.15"
            android:layout_marginBottom="14dp"/>

        <ProgressBar
            android:id="@+id/progress_bar"
            style="@style/Widget.AppCompat.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:progressTint="@color/accent"
            android:progressBackgroundTint="@color/divider"
            android:max="100"
            android:progress="0"/>

    </LinearLayout>

    <!-- Content middle -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingTop="52dp">

        <TextView
            android:id="@+id/tv_perm_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="28sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:lineSpacingMultiplier="1.15"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tv_perm_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:lineSpacingMultiplier="1.55"
            android:layout_marginBottom="28dp"/>

        <TextView
            android:id="@+id/tv_perm_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="sans-serif"
            android:lineSpacingMultiplier="1.5"
            android:background="@drawable/bg_info_box"
            android:padding="16dp"/>

    </LinearLayout>

    <!-- Bottom CTA -->
    <Button
        android:id="@+id/btn_grant"
        style="@style/Widget.Focused.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_marginBottom="40dp"
        android:text="Grant access"/>

</LinearLayout>
