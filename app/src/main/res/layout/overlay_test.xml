<?xml version="1.0" encoding="utf-8"?>
<!--
    overlay_test.xml
    Used only during development to verify WindowManager overlays render correctly.
    Not shown in production.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#F0F0F0"
    android:padding="20dp"
    android:gravity="center">
    <TextView
        android:id="@+id/tv_test_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Focused overlay working ✓"
        android:textSize="@dimen/text_subtitle"
        android:textColor="#1A1A1A"
        android:fontFamily="sans-serif-medium" />
    <TextView
        android:id="@+id/tv_test_sub"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="WindowManager + SYSTEM_ALERT_WINDOW confirmed"
        android:textSize="@dimen/text_label"
        android:textColor="#666666"
        android:layout_marginTop="4dp" />
</LinearLayout>