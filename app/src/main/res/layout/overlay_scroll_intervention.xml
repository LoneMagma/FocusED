<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_bottom_card"
    android:paddingStart="28dp"
    android:paddingEnd="28dp"
    android:paddingTop="16dp"
    android:paddingBottom="28dp">

    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="24dp"
        android:background="@drawable/bg_drag_handle"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Still scrolling?"
        android:textSize="24sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-medium"
        android:layout_marginBottom="10dp"/>

    <TextView
        android:id="@+id/tv_scroll_duration"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="28dp"/>

    <!-- btn_scroll_break = "I'm done" (primary action) -->
    <Button
        android:id="@+id/btn_scroll_break"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:text="I'm done scrolling"
        android:textSize="15sp"
        android:textColor="@color/btn_primary_text"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_primary"
        android:layout_marginBottom="10dp"/>

    <!-- btn_scroll_keepgoing = snooze -->
    <Button
        android:id="@+id/btn_scroll_keepgoing"
        android:layout_width="match_parent"
        android:layout_height="46dp"
        android:text="5 more minutes"
        android:textSize="14sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="sans-serif"
        android:background="@drawable/bg_btn_ghost"/>

    <!-- Keep old IDs too for any other references -->
    <Button
        android:id="@+id/btn_scroll_dismiss"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"/>

    <Button
        android:id="@+id/btn_scroll_snooze"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"/>

</LinearLayout>
