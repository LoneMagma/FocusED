<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary"
    android:paddingStart="32dp"
    android:paddingEnd="32dp">

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Hold on."
        android:textSize="42sp"
        android:textColor="@color/text_primary"
        android:fontFamily="sans-serif-black"
        android:layout_marginBottom="18dp"/>

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You're trying to disable Focused."
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.5"
        android:layout_marginBottom="12dp"/>

    <TextView
        android:id="@+id/tv_tier1_stats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="sans-serif"
        android:lineSpacingMultiplier="1.4"
        android:layout_marginBottom="20dp"/>

    <TextView
        android:id="@+id/tv_tier1_countdown"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="@color/text_tertiary"
        android:fontFamily="monospace"
        android:visibility="gone"/>

    <View android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1"/>

    <View android:layout_width="match_parent" android:layout_height="1dp" android:background="@color/divider"/>

    <Button
        android:id="@+id/btn_tier1_continue"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="I still want to disable it"
        android:textSize="13sp"
        android:textColor="@color/text_disabled"
        android:fontFamily="sans-serif"
        android:background="@drawable/bg_btn_ghost"/>

    <Button
        android:id="@+id/btn_tier1_cancel"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:text="Never mind, stay focused"
        android:textSize="14sp"
        android:textColor="@color/text_secondary"
        android:fontFamily="sans-serif-medium"
        android:background="@drawable/bg_btn_secondary"/>

</LinearLayout>
