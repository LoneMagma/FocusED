<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Top bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="24dp"
        android:paddingEnd="16dp"
        android:paddingTop="54dp"
        android:paddingBottom="0dp"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_app_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="FocusED"
            android:textSize="12sp"
            android:textColor="@color/text_tertiary"
            android:fontFamily="sans-serif-medium"
            android:letterSpacing="0.25"/>

        <Button
            android:id="@+id/btn_stats"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Stats"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:minWidth="0dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_btn_secondary"/>

        <Button
            android:id="@+id/btn_view_log"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Log"
            android:textSize="13sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"
            android:minWidth="0dp"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:background="@drawable/bg_btn_secondary"/>

    </LinearLayout>

    <!-- Status hero section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:gravity="center_vertical">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="18dp">

            <View
                android:id="@+id/status_dot"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/dot_amber"
                android:layout_marginEnd="10dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="STATUS"
                android:textSize="11sp"
                android:textColor="@color/text_tertiary"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.20"/>

        </LinearLayout>

        <!-- Big status word -->
        <TextView
            android:id="@+id/tv_service_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Inactive"
            android:textSize="52sp"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="-0.02"
            android:layout_marginBottom="12dp"/>

        <!-- Sub-status -->
        <TextView
            android:id="@+id/tv_status_sub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap below to enable"
            android:textSize="16sp"
            android:textColor="@color/text_secondary"
            android:fontFamily="sans-serif"/>

    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- App rows -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:overScrollMode="never">

        <LinearLayout
            android:id="@+id/container_app_rows"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_no_apps"
                android:layout_width="match_parent"
                android:layout_height="72dp"
                android:text="No apps configured — tap Manage apps"
                android:textSize="15sp"
                android:textColor="@color/text_tertiary"
                android:fontFamily="sans-serif"
                android:gravity="center_vertical"
                android:paddingStart="24dp"
                android:visibility="visible"/>

        </LinearLayout>
    </ScrollView>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"/>

    <!-- Bottom actions -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="32dp">

        <!-- Primary CTA -->
        <Button
            android:id="@+id/btn_primary_action"
            style="@style/Widget.Focused.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="ENABLE FocusED"/>

        <!-- Secondary row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btn_focus_mode"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="Focus mode"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_btn_secondary"/>

            <Button
                android:id="@+id/btn_manage_apps"
                android:layout_width="0dp"
                android:layout_height="46dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="Manage apps"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"
                android:background="@drawable/bg_btn_secondary"/>

        </LinearLayout>

        <Button
            android:id="@+id/btn_fix_permissions"
            style="@style/Widget.Focused.Button.Ghost"
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:text="Fix permissions →"
            android:visibility="gone"/>

    </LinearLayout>

</LinearLayout>
