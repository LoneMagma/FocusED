<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.Focused" parent="Theme.MaterialComponents.NoActionBar">
        <item name="colorPrimary">#F0F0F0</item>
        <item name="colorPrimaryVariant">#F0F0F0</item>
        <item name="colorOnPrimary">#0A0A0A</item>
        <item name="colorSecondary">#F0F0F0</item>
        <item name="colorOnSecondary">#0A0A0A</item>
        <item name="colorSurface">@color/bg_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorError">#C0C0C0</item>
        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">@color/bg_primary</item>
        <item name="android:windowLightNavigationBar" tools:targetApi="o_mr1">false</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="android:textColorHighlight">#33F0F0F0</item>
        <!-- Override button styles globally so no button accidentally gets white-on-white -->
        <item name="materialButtonStyle">@style/Widget.Focused.Button.Secondary</item>
        <item name="android:buttonStyle">@style/Widget.Focused.Button.Secondary</item>
    </style>

    <!-- Primary: white pill, black text — use for the main CTA -->
    <style name="Widget.Focused.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_btn_primary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">#0A0A0A</item>
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
        <item name="android:minHeight">52dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">#22000000</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Secondary: dark card, light grey text — use for secondary actions -->
    <style name="Widget.Focused.Button.Secondary" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/bg_btn_secondary</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">#B8B8B8</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:paddingStart">20dp</item>
        <item name="android:paddingEnd">20dp</item>
        <item name="android:minHeight">46dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="rippleColor">#33FFFFFF</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <!-- Ghost: transparent with border, used for subtle/danger actions -->
    <style name="Widget.Focused.Button.Ghost" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:background">@drawable/bg_btn_ghost</item>
        <item name="backgroundTint">@null</item>
        <item name="strokeColor">#2A2A2A</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">#666666</item>
        <item name="android:textSize">13sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:minHeight">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="cornerRadius">14dp</item>
        <item name="elevation">0dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

</resources>
